# Purinina configuration (copy to .env and edit).
# These are read by the host launcher and/or passed into the sandbox container.

# --- Sandbox image / container ---
PURININA_IMAGE=purinina:latest
PURININA_CONTAINER=purinina-sandbox

# Host directory to mount as the working/loot directory inside the sandbox.
# Defaults to ./engagement next to where you launch purinina.
PURININA_WORKSPACE=./engagement

# Pinned opencode version baked into the image (see docker/Dockerfile).
OPENCODE_VERSION=1.17.8

# --- Human-In-The-Loop (HITL) policy ---
# strict  = ask before every potentially intrusive action (default, safest)
# guided  = ask before high-impact actions only (exploitation, writes, exfil)
# auto    = no prompts (DANGEROUS — only for isolated labs/CTF you fully own)
PURININA_HITL=strict

# --- Model provider auth ---
# By default the launcher mounts your host opencode auth read-only:
#   ~/.local/share/opencode/auth.json  ->  container (read-only)
# Alternatively, provide keys here and set PURININA_AUTH_MODE=env.
PURININA_AUTH_MODE=mount
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Default model for the orchestrator and agents (provider/model form).
PURININA_MODEL=anthropic/claude-opus-4-8
